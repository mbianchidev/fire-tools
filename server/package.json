{
  "name": "fire-tools-server",
  "version": "1.0.0",
  "description": "Local-deployment backend for Fire Tools (SQLite-first, Postgres-compatible). Implements docs/api/openapi.yaml.",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint:tsc": "tsc --noEmit",
    "pretest": "node ../scripts/ensure-sqlite-for-node.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/cli-migrate.ts up",
    "migrate:down": "tsx src/cli-migrate.ts down",
    "migrate:status": "tsx src/cli-migrate.ts status"
  },
  "dependencies": {
    "better-sqlite3": "npm:better-sqlite3-multiple-ciphers@^12.10.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.7"
  }
}
