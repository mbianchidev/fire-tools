# Example env for the local docker-compose stack.
# Copy to `.env` and tweak. Compose picks it up automatically.

# Backend
NODE_ENV=production
PORT=8787
HOST=0.0.0.0
# `file:` for SQLite (default) or `postgres://…` once the driver is wired.
DATABASE_URL=file:/data/firetools.db
SCHEMA_PATH=/app/schema/schema.sql
# Tighten this to your frontend origin in production.
CORS_ORIGIN=http://localhost:8080
